# Database — Supabase Postgres
# 1. Create a project at https://supabase.com/dashboard
# 2. Settings → Database → Connection string → URI (Transaction mode for serverless)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=public"
# 3. Settings → API → Direct connection (for migrations)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"

# OpenAI (optional, for AI analysis)
OPENAI_API_KEY="sk-..."

# Supabase Storage (for PDF uploads)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Email (optional, for expiration reminders)
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"

# Cron security (optional, for /api/cron endpoints)
CRON_SECRET="generate-a-random-string"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STORAGE_PROVIDER="supabase"
